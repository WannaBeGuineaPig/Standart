{
  "openapi": "3.0.1",
  "info": {
    "title": "Shestorka_API",
    "version": "1.0"
  },
  "paths": {
    "/category": {
      "get": {
        "tags": [
          "Category"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/eats": {
      "get": {
        "tags": [
          "Eat"
        ],
        "parameters": [
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sorting",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "по возрастанию"
            }
          },
          {
            "name": "filtering",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "Все поставщики"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/eat-ordering": {
      "post": {
        "tags": [
          "Eat"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "text/json": {
              "schema": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "application/*+json": {
              "schema": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/item-on-articul": {
      "get": {
        "tags": [
          "Eat"
        ],
        "parameters": [
          {
            "name": "articul",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/add-eat": {
      "post": {
        "tags": [
          "Eat"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EatClass"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/EatClass"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/EatClass"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/change-eat": {
      "put": {
        "tags": [
          "Eat"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EatClass"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/EatClass"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/EatClass"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/delete-eat": {
      "delete": {
        "tags": [
          "Eat"
        ],
        "parameters": [
          {
            "name": "articul",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/manafacturer": {
      "get": {
        "tags": [
          "Manafacturer"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/order": {
      "get": {
        "tags": [
          "Order"
        ],
        "parameters": [
          {
            "name": "idUser",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": -1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/new-order": {
      "post": {
        "tags": [
          "Order"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OrderClass"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/OrderClass"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/OrderClass"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/address-pick-up-point": {
      "get": {
        "tags": [
          "PickUpPoint"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/supplier": {
      "get": {
        "tags": [
          "Supplier"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/type": {
      "get": {
        "tags": [
          "Type"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/users": {
      "get": {
        "tags": [
          "User"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/authorization": {
      "post": {
        "tags": [
          "User"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AuthorizationUser"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/AuthorizationUser"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/AuthorizationUser"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AuthorizationUser": {
        "type": "object",
        "properties": {
          "mail": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "EatClass": {
        "type": "object",
        "properties": {
          "articul": {
            "type": "string",
            "nullable": true
          },
          "type": {
            "type": "string",
            "nullable": true
          },
          "unitOfMeasurement": {
            "type": "string",
            "nullable": true
          },
          "price": {
            "type": "integer",
            "format": "int32"
          },
          "supplier": {
            "type": "string",
            "nullable": true
          },
          "manafacturer": {
            "type": "string",
            "nullable": true
          },
          "category": {
            "type": "string",
            "nullable": true
          },
          "discountPercent": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "amountInStorage": {
            "type": "integer",
            "format": "int32"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "image": {
            "type": "string",
            "format": "byte",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "OrderClass": {
        "type": "object",
        "properties": {
          "idUser": {
            "type": "integer",
            "format": "int32"
          },
          "dateOrdering": {
            "type": "string",
            "format": "date"
          },
          "dateDelivery": {
            "type": "string",
            "format": "date"
          },
          "status": {
            "type": "string",
            "nullable": true
          },
          "addressPickUpPoint": {
            "type": "string",
            "nullable": true
          },
          "itemOrder": {
            "type": "object",
            "additionalProperties": {
              "type": "integer",
              "format": "int32"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
}