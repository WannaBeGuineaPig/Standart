<Window x:Class="Shoes_Demo_Ekz.Windows.AddChangeDeleteOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Shoes_Demo_Ekz.Windows"
        mc:Ignorable="d"
            Title="ООО 'Обувь' - " Height="600" Width="800" Background="#FFFFFF" FontFamily="Times New Roman" ResizeMode="NoResize" WindowStartupLocation="CenterScreen" Closing="Window_Closing">
    <Grid ScrollViewer.CanContentScroll="True">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <StackPanel Grid.ColumnSpan="4" Background="#00FA9A"/>
        <Button Name="ExitAccountBTN" Content="Закрыть" FontSize="18" Background="White" Grid.Column="3" Height="50" Width="100" BorderBrush="Black" Click="ExitAccountBTN_Click"/>

        <ScrollViewer Grid.Row="1" Grid.ColumnSpan="4" Grid.RowSpan="4" Margin="0 20 0 0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0 20 0 0">
                    <TextBlock x:Name="IdOrderTBL" FontSize="16" VerticalAlignment="Center" Visibility="Collapsed"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0 20 0 0">
                    <TextBlock x:Name="IdCodePickUpTBL" FontSize="16" VerticalAlignment="Center" Visibility="Collapsed"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0 20 0 0">
                    <TextBlock Name="DateOrderingTBL" FontSize="16" Text="Дата заказа: " VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0 20 0 0">
                    <TextBlock FontSize="16" Text="Статус заказа: " VerticalAlignment="Center"/>
                    <ComboBox Name="StatusOrderCB" FontSize="16" Width="300" SelectedIndex="0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0 20 0 0">
                    <TextBlock FontSize="16" Text="Адрес заказа: " VerticalAlignment="Center"/>
                    <ComboBox Name="AddressOrderCB" FontSize="16" Width="300" SelectedIndex="0"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0 20 0 0">
                    <TextBlock FontSize="16" Text="Пользователь заказа заказа: " VerticalAlignment="Center"/>
                    <ComboBox Name="UserOrderCB" FontSize="16" Width="300" SelectedIndex="0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0 20 0 0">
                    <TextBlock FontSize="16" Text="Дата выдачи: " VerticalAlignment="Center"/>
                    <DatePicker Name="DateDeliveryDP" FontSize="16" Width="300" SelectedDateFormat="Short"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0 20 0 0">
                    <TextBlock Name="OrderItemsTBL" Visibility="Collapsed" FontSize="16" VerticalAlignment="Center"/>
                    <ListView x:Name="OrderItemsLV" Visibility="Collapsed">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Width="500" Orientation="Horizontal">
                                    <TextBlock Text="Артикул обуви: " FontSize="16"/>
                                    <TextBlock Name="articulShoes" Text="{Binding ArticulItem}" FontSize="16" Margin="10 0 0 0"/>
                                    <TextBlock Text="Количество в заказе: " FontSize="16" Margin="30 0 0 0"/>
                                    <TextBox Text="{Binding AmountItem}"  MinWidth="80" PreviewTextInput="TextBox_PreviewTextInput" MaxLength="5" FontSize="16"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 20 0 10">
                    <Button Name="addChangeBTN" FontSize="16" Width="200" Height="50" Background="Transparent" BorderBrush="#00FA9A" BorderThickness="2" Margin="0 0 20 0" Click="addChangeBTN_Click"/>
                    <Button Name="deleteBTN" Visibility="Collapsed" Content="Удаление товара" FontSize="16" Width="200" Height="50" Background="Transparent" BorderBrush="red" BorderThickness="2" Click="deleteBTN_Click"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
