<Window x:Class="Shoes_Demo_Ekz.Windows.AddChangeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Shoes_Demo_Ekz.Windows"
        mc:Ignorable="d"
        Title="ООО 'Обувь' - " Height="800" Width="1000" Background="#FFFFFF" FontFamily="Times New Roman" ResizeMode="NoResize" WindowStartupLocation="CenterScreen" Closing="Window_Closing">
    <Grid ScrollViewer.CanContentScroll="True">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <StackPanel Grid.ColumnSpan="4" Background="#00FA9A"/>
        <Button Name="ExitAccountBTN" Content="Закрыть" FontSize="18" Background="White" Grid.Column="3" Height="50" Width="100" BorderBrush="Black" Click="ExitAccountBTN_Click"/>

        <ScrollViewer Grid.Row="1" Grid.ColumnSpan="4" Grid.RowSpan="4" Margin="0 20 0 0">
            <StackPanel>
                <Image Name="imageItem" Source="/Images/picture.png" MaxWidth="200" MaxHeight="200"/>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0 20 0 0">
                    <Button Name="changeImageBTN" Content="Изменить фото товара" FontSize="16" Background="Transparent" BorderBrush="#00FA9A" Width="200" Height="30" Click="changeImageBTN_Click"/>
                </StackPanel>
            
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0 20 0 0">
                    <TextBlock x:Name="articulItemTBL" Text="Артикул товара: " Visibility="Collapsed" FontSize="16"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0 20 0 0">
                    <TextBlock FontSize="16" Text="Наименования товара: " VerticalAlignment="Center"/>
                    <ComboBox Name="typeItemCB" FontSize="16" Width="300" SelectedIndex="0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0 20 0 0">
                    <TextBlock FontSize="16" Text="Категория товара: " VerticalAlignment="Center"/>
                    <ComboBox Name="categoryItemCB" FontSize="16" Width="300" SelectedIndex="0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0 20 0 0">
                    <TextBlock FontSize="16" Text="Описание товара: " VerticalAlignment="Center"/>
                    <TextBox Name="descriptionItemTB" MaxLength="500" TextWrapping="Wrap" AcceptsReturn="True" FontSize="16" Width="500" Height="150" VerticalScrollBarVisibility="Auto"/>
                </StackPanel>
            
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0 20 0 0">
                    <TextBlock FontSize="16" Text="Производитель товара: " VerticalAlignment="Center"/>
                    <ComboBox Name="manafacturerItemCB" FontSize="16" Width="300" SelectedIndex="0"/>
                </StackPanel>
            
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0 20 0 0">
                    <TextBlock FontSize="16" Text="Поставщик товара: " VerticalAlignment="Center"/>
                    <ComboBox Name="supplierItemCB" FontSize="16" Width="300" SelectedIndex="0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0 20 0 0">
                    <TextBlock FontSize="16" Text="Цена товара: " VerticalAlignment="Center"/>
                    <TextBox Name="priceItemTB" FontSize="16" Width="300" MaxLength="9"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0 20 0 0">
                    <TextBlock FontSize="16" Text="Единица измерения товара: " VerticalAlignment="Center"/>
                    <ComboBox Name="unitOfMeasureItemCB" FontSize="16" Width="300" SelectedIndex="0"/>
                </StackPanel>
            
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0 20 0 0">
                    <TextBlock FontSize="16" Text="Количество товара на складе: " VerticalAlignment="Center"/>
                    <TextBox Name="amountInStorageItemTB" FontSize="16" Width="300" MaxLength="10"/>
                </StackPanel>
            
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0 20 0 0">
                    <TextBlock FontSize="16" Text="Действующая скидка товара(%): " VerticalAlignment="Center"/>
                    <TextBox Name="discountItemTB" FontSize="16" Width="300" MaxLength="2"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 20 0 10">
                    <Button Name="addChangeBTN" FontSize="16" Width="200" Height="50" Background="Transparent" BorderBrush="#00FA9A" BorderThickness="2" Margin="0 0 20 0" Click="addChangeBTN_Click"/>
                    <Button Name="deleteBTN" Visibility="Collapsed" Content="Удаление товара" FontSize="16" Width="200" Height="50" Background="Transparent" BorderBrush="Red" BorderThickness="2" Click="deleteBTN_Click"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
