<Window x:Class="Shoes_Demo_Ekz.Windows.AuthorizationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Shoes_Demo_Ekz.Windows"
        mc:Ignorable="d"
        Title="ООО 'Обувь' - Авторизация" MinHeight="450" MinWidth="850" Background="#FFFFFF" FontFamily="Times New Roman" WindowState="Maximized">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <TextBlock Text="Авторизация" FontSize="30" Grid.ColumnSpan="4" VerticalAlignment="Bottom"  HorizontalAlignment="Center" Margin="0,0,0,10"/>
        <TextBlock Text="Введите почту:" FontSize="20" Grid.Column="1" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>
        <TextBox Text="94d5ous@gmail.com" Name="MailTB" MaxLength="40" FontSize="16" Grid.Column="2" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Left" Width="185" Margin="5,0,0,0" BorderBrush="#00FA9A" BorderThickness="2"/>
        <TextBlock Text="Введите пароль:" FontSize="20" Grid.Column="1" Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>
        <TextBox Text="uzWC67" Name="PasswordTB" MaxLength="40" FontSize="16" Grid.Column="2" Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Left" Width="185" Margin="5,0,0,0" BorderBrush="#00FA9A" BorderThickness="2"/>
        <Button Name="AuthBTN" Content="Войти" FontSize="20" Grid.ColumnSpan="4" Grid.Row="3" VerticalAlignment="Center" HorizontalAlignment="Center" Width="200" Height="50" Background="#FFFFFF" BorderBrush="#7FFF00" BorderThickness="2" Click="AuthBTN_Click"/>
        <Button Name="GuestEnterBTN" Content="Войти(как гость)" FontSize="20" Grid.ColumnSpan="4" Grid.Row="4" VerticalAlignment="Center" HorizontalAlignment="Center" Width="200" Height="50" Background="#FFFFFF" BorderBrush="#00FA9A" BorderThickness="2" Click="GuestEnterBTN_Click"/>
    </Grid>
</Window>
