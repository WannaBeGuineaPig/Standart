<Window x:Class="Shoes_Demo_Ekz.Windows.CatalogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Shoes_Demo_Ekz.Windows"
        mc:Ignorable="d"
        Title="ООО 'Обувь' - магазин" MinHeight="450" MinWidth="850" Background="#FFFFFF" FontFamily="Times New Roman" WindowState="Maximized">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <StackPanel Grid.ColumnSpan="4" Background="#00FA9A"/>
        <TextBlock Name="RoleUserTBL" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18"/>
        <TextBlock Name="FIOUserTBL" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" TextWrapping="Wrap"/>
        <Button Name="OrdersBTN" Content="Заказы" Visibility="Collapsed" FontSize="18" Background="White" Grid.Column="2" Height="50" Width="100" BorderBrush="Black" Click="OrdersBTN_Click"/>
        <Button Name="ExitAccountBTN" Content="Выйти"  FontSize="18" Background="White" Grid.Column="3" Height="50" Width="100" BorderBrush="Black" Click="ExitAccountBTN_Click"/>

        <ScrollViewer Grid.ColumnSpan="4" Grid.Row="1" Grid.RowSpan="4">
            <StackPanel>
                <StackPanel x:Name="changeOutDataSP" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0 10 0 10">
                    <StackPanel Orientation="Horizontal" Margin="0 10 0 0" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Поиск обуви по всем данным:" FontSize="16" Margin="0 0 5 0" VerticalAlignment="Center"/>
                        <TextBox Name="searchShoesTB" FontSize="16" Width="250" TextChanged="searchShoesTB_TextChanged"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0 10 0 0" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Сортировка обвуи по количеству на складе:" FontSize="16" Margin="0 0 5 0" VerticalAlignment="Center"/>
                        <ComboBox Name="sortingShoesCB" MinWidth="250" SelectedIndex="0" FontSize="16" SelectionChanged="sortingShoesCB_SelectionChanged"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0 10 0 0" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Фильтрации обуви по поставщику:" FontSize="16" Margin="0 0 5 0" VerticalAlignment="Center"/>
                        <ComboBox Name="filteringShoesCB" MinWidth="250" SelectedIndex="0" FontSize="16" SelectionChanged="filteringShoesCB_SelectionChanged"/>
                    </StackPanel>
                </StackPanel>
                <TextBlock Name="NotFoundTB" FontSize="16" Text="Обувь не найдена!" VerticalAlignment="Center" HorizontalAlignment="Center"  Visibility="Collapsed"/>
                <ListView Name="CatalogBoxLV" HorizontalContentAlignment="Center" MouseDoubleClick="CatalogBoxLV_MouseDoubleClick">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="Black" BorderThickness="2" HorizontalAlignment="Center">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="1*" MinWidth="800"/>
                                        <ColumnDefinition Width="200"/>
                                    </Grid.ColumnDefinitions>
                                    <Border BorderBrush="Black" BorderThickness="1" Margin="5">
                                        <Image Source="{Binding Photo}" Margin="5"/>
                                    </Border>
                                    <Border Grid.Column="1" BorderBrush="Black" BorderThickness="1" Margin="5">
                                        <StackPanel Margin="5" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                <TextBlock FontSize="16" Text="{Binding IdTypeNavigation.Type}"/>
                                                <TextBlock FontSize="16" Text="|" Margin="5 0 5 0"/>
                                                <TextBlock FontSize="16" Text="{Binding IdCategoryNavigation.Category}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                <TextBlock FontSize="16" Text="Описание товара:" Margin="0 0 5 0"/>
                                                <TextBlock FontSize="16" Text="{Binding Description}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                <TextBlock FontSize="16" Text="Производитель:" Margin="0 0 5 0"/>
                                                <TextBlock FontSize="16" Text="{Binding IdManafacturerNavigation.Manafacturer1}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                <TextBlock FontSize="16" Text="Поставщик:" Margin="0 0 5 0"/>
                                                <TextBlock FontSize="16" Text="{Binding IdSupplierNavigation.Supplier1}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Background="{Binding BigDiscount}">
                                                <TextBlock FontSize="16" Text="Цена:" Margin="0 0 5 0"/>
                                                <TextBlock FontSize="16" Text="{Binding Price}" Foreground="{Binding ColorPrice}" TextDecorations="{Binding StylePrice}"/>
                                                <TextBlock FontSize="16" Text="{Binding NewPrice}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                <TextBlock FontSize="16" Text="Единица измерения:" Margin="0 0 5 0"/>
                                                <TextBlock FontSize="16" Text="{Binding UnitOfMeasurement}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Background="{Binding ColorAmountInStorage}">
                                                <TextBlock FontSize="16" Text="Количество на складе:" Margin="0 0 5 0"/>
                                                <TextBlock FontSize="16" Text="{Binding AmountInStorage}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Margin="5" BorderThickness="1" BorderBrush="Black">
                                        <TextBlock Text="{Binding DiscountString}" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <Button Name="addShoesBTN" Content="Добавить заказ" Width="200" Height="40" FontSize="16" Background="Transparent" BorderBrush="#00FA9A" BorderThickness="2" Margin="0 10 0 10" Visibility="Collapsed" Click="addShoesBTN_Click"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>

