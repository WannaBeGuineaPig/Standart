<Window x:Class="Shoes_Demo_Ekz.Windows.OrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Shoes_Demo_Ekz.Windows"
        mc:Ignorable="d"
        Title="ООО 'Обувь' - заказы" MinHeight="450" MinWidth="850" Background="#FFFFFF" FontFamily="Times New Roman" WindowState="Maximized">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <StackPanel Grid.ColumnSpan="4" Background="#00FA9A"/>
        <TextBlock Name="RoleUserTBL" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18"/>
        <TextBlock Name="FIOUserTBL" Grid.Column="1" Grid.ColumnSpan="2" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" TextWrapping="Wrap"/>
        <Button Name="ReturnBTN" Content="Назад" FontSize="18" Background="White" Grid.Column="3" Height="50" Width="100" BorderBrush="Black" Click="ReturnBTN_Click"/>

        <ScrollViewer Grid.ColumnSpan="4" Grid.Row="1" Grid.RowSpan="4">
            <StackPanel>
                <ListView Name="OrderBoxLV" HorizontalContentAlignment="Center" MouseDoubleClick="OrderBoxLV_MouseDoubleClick">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="Black" BorderThickness="2" HorizontalAlignment="Center">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*" MinWidth="800"/>
                                        <ColumnDefinition Width="200"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <Border BorderBrush="Black" BorderThickness="1" Margin="5">
                                        <StackPanel Margin="5">
                                            <TextBlock FontSize="16" Text="{Binding Id}"/>
                                            <TextBlock FontSize="16" Text="{Binding Status}"/>
                                            <TextBlock FontSize="16" Text="{Binding IdPickupPointNavigation.Address}"/>
                                            <TextBlock FontSize="16" Text="{Binding DateOrderingString}"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <Border Grid.Column="1" BorderBrush="Black" BorderThickness="2" Margin="5">
                                        <StackPanel Margin="5">
                                            <TextBlock FontSize="16" Text=""/>
                                            <TextBlock FontSize="16" Text="{Binding DateDeliveryString}"/>
                                        </StackPanel>
                                    </Border>
                                    
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <Button Name="addOrderBTN" Content="Добавить заказ" Visibility="Collapsed" Width="200" Height="40" FontSize="16" Background="Transparent" BorderBrush="#00FA9A" BorderThickness="2" Margin="0 10 0 10" Click="addOrderBTN_Click"/>
            </StackPanel>
        </ScrollViewer>

    </Grid>
</Window>
